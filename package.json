{
  "name": "lido-mcp",
  "version": "1.0.0",
  "description": "MCP server for Lido staking operations \u2014 stake, unstake, wrap, unwrap, governance, and vault monitoring",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lido-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --test test/tools.test.cjs",
    "pretest": "npm run build"
  },
  "keywords": [
    "mcp",
    "lido",
    "staking",
    "ethereum",
    "steth",
    "wsteth",
    "defi"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "viem": "^2.27.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3"
  },
  "engines": {
    "node": ">=18"
  }
}
